PORT=5000
NODE_ENV=development

# Cấu hình Database MS SQL Server
DB_USER=sa
DB_PASSWORD=your_db_password
DB_SERVER=localhost
DB_INSTANCE=SQLEXPRESS01
DB_DATABASE=ParkingManagementDB
DB_ENCRYPT=false
DB_TRUST_SERVER_CERTIFICATE=true

# Cấu hình bảo mật JWT
ACCESS_TOKEN_SECRET=your_jwt_access_secret_key
ACCESS_TOKEN_EXPIRES=15m
REFRESH_TOKEN_SECRET=your_jwt_refresh_secret_key
REFRESH_TOKEN_EXPIRES=7d
SESSION_ABSOLUTE_EXPIRES=45d

# CORS & Cổng kết nối Frontend
FE_ORIGIN=http://localhost:5173
VITE_API_URL=http://localhost:5000/api

# Đăng nhập bên thứ ba (Google)
GOOGLE_CLIENT_ID=your_google_client_id

# Cấu hình gửi Mail (SMTP Gmail)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_gmail_username@gmail.com
SMTP_PASS=your_gmail_app_password

# ĐỊA CHỈ NHẬN EMAIL THỬ NGHIỆM (Hỗ trợ xác thực các tài khoản test như alice@email.com, bob@email.com...)
# Điền email thật của bạn vào đây để nhận mọi email chuyển hướng từ hệ thống trong quá trình chạy thử (development).
SMTP_TEST_RECEIVER=your_real_email_for_testing@gmail.com

# Cấu hình thanh toán PayOS
PAYOS_CLIENT_ID=your_payos_client_id
PAYOS_API_KEY=your_payos_api_key
PAYOS_CHECKSUM_KEY=your_payos_checksum_key

# Cấu hình AI Assistant Gemini
GEMINI_API_KEY=your_gemini_api_key

DB_USER & DB_PASSWORD: Tài khoản/Mật khẩu đăng nhập SQL Server của máy .
DB_INSTANCE: Tên Instance SQL Server trên máy  (Ví dụ: SQLEXPRESS hoặc SQLEXPRESS01).
SMTP_USER & SMTP_PASS: Gmail và Mật khẩu ứng dụng (App Password) của  để gửi mail.
SMTP_TEST_RECEIVER: Điền Email thật của người chạy (Ví dụ: email cá nhân của giáo viên hoặc bạn học) để nhận thư xác thực chuyển hướng của các tài khoản test (alice@email.com, bob@email.com...).